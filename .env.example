# Copy this file to `.env.local` and fill in your values.
# Restart the dev server after changing environment variables.

# ── Meta Pixel (Facebook) ──────────────────────────────────────────────────────
# Your Pixel ID from Meta Events Manager → Data Sources → Pixels.
# Exported in code as META_PIXEL_ID (requires NEXT_PUBLIC_ prefix for the browser).
NEXT_PUBLIC_META_PIXEL_ID=

# ── Google Analytics 4 ───────────────────────────────────────────────────────
# Measurement ID from GA4 → Admin → Data Streams (format: G-XXXXXXXXXX).
# Exported in code as GA_MEASUREMENT_ID (requires NEXT_PUBLIC_ prefix for the browser).
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# ── Google Search Console ──────────────────────────────────────────────────────
# HTML tag verification content from Search Console → Settings → Ownership verification.
# Use only the content value, not the full meta tag.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# ── Google Business / Reviews (optional) ─────────────────────────────────────
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=
